// Networky.ai (PNIS) — Phase 1 schema.
// SQLite for local-first development. Swappable to Supabase Postgres later
// by changing the datasource provider + url and re-running migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contact {
  id        String   @id @default(cuid())
  // Supabase auth user id (auth.users.id) of the owner. Nullable so existing
  // rows stay valid and the app runs in open/shared mode until auth is enabled.
  userId    String?
  name      String
  email     String?
  phone     String?
  company   String?
  title     String?
  location  String?
  tags      String? // comma-separated (SQLite has no native arrays)
  // Birthday in a normalized, year-optional form: "YYYY-MM-DD" when the year is
  // known, or "--MM-DD" (ISO 8601 / vCard convention) when it isn't.
  birthday  String?
  howWeMet     String?  // context: where/how the connection was made
  customFields String?  // JSON: AI-detected extra fields {"Interests": "...", "Hobbies": "..."}

  // AI-assisted profile
  profile          String?
  profileModel     String?
  profileUpdatedAt DateTime?

  notes Note[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([company])
  @@index([userId])
}

model Note {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  content String
  source  String @default("manual") // "manual" | "voice" | "story"

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}
