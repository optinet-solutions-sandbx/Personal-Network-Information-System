// Networky.ai (PNIS) — Phase 1 schema.
// Supabase Postgres (migrated from initial local SQLite on 2026-06-15).
// Pooler split: DATABASE_URL (transaction/6543) + DIRECT_URL (session/5432, migrations).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Contact {
  id           String  @id @default(cuid())
  // Supabase auth user id (auth.users.id) of the owner. Nullable so existing
  // rows stay valid and the app runs in open/shared mode until auth is enabled.
  userId       String?
  // Workspace this contact belongs to. Nullable + additive for now: ownership is
  // still enforced via userId (see lib/auth.ts). Workspaces (User/Workspace/
  // WorkspaceMember below) are landed as data-model groundwork for the upcoming
  // workspaces epic; routes will adopt workspace scoping in a later sub-project.
  workspaceId  String?
  name         String
  email        String?
  phone        String?
  company      String?
  title        String?
  location     String?
  tags         String? // comma-separated (kept as scalar string from the original SQLite scaffold)
  // Birthday in a normalized, year-optional form: "YYYY-MM-DD" when the year is
  // known, or "--MM-DD" (ISO 8601 / vCard convention) when it isn't.
  birthday     String?
  howWeMet     String? // context: where/how the connection was made
  customFields String? // JSON: AI-detected extra fields {"Interests": "...", "Hobbies": "..."}

  // Provenance for synced/imported contacts (Phase 3 connectors). `source` is the
  // origin system ("manual" default | "csv" | "hubspot" | "google" | "salesforce"
  // | "linkedin"); `externalId` is that system's record id. Together with
  // workspaceId they let a re-sync UPDATE the existing row instead of creating a
  // duplicate (see lib/connectors/sync.ts). Both nullable so existing/manual rows
  // stay valid.
  source       String? @default("manual")
  externalId   String?

  // Immutable archive of the raw input this contact was created from (the
  // freeform add-flow conversation + any attached photos), captured once at
  // creation and never edited afterwards. Kept separate from the editable
  // "story" Note so the original is always recoverable for a future
  // re-analyze/reset, even if the note is changed or deleted.
  sourceText   String?  // the original typed/dictated text, joined across messages
  sourceImages String[] @default([]) // original photos as data URLs (see lib/image.ts)

  // AI-assisted profile
  profile          String?
  profileModel     String?
  profileUpdatedAt DateTime?

  // Relationship health score
  healthScore  Int?
  healthTier   String?
  healthInputs String?

  // Follow-up cadence
  followUpCadence     String?  // "weekly" | "monthly" | "quarterly" | "annually" | "custom"
  followUpCadenceDays Int?     // days between follow-ups; only used when followUpCadence = "custom"

  notes          Note[]
  suggestionsAsA Suggestion[] @relation("SuggestionA")
  suggestionsAsB Suggestion[] @relation("SuggestionB")
  relationshipsFrom Relationship[] @relation("RelFrom")
  relationshipsTo   Relationship[] @relation("RelTo")
  workspace      Workspace?   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([company])
  @@index([userId])
  @@index([workspaceId])
  // Fast lookup for re-sync dedupe: find an existing contact by its origin id
  // within a workspace.
  @@index([workspaceId, source, externalId])
}

model Note {
  id        String  @id @default(cuid())
  contactId String
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  content String
  source  String @default("manual") // "manual" | "voice" | "story" | "gift"
  // Photo attachments as downscaled JPEG data URLs (see lib/image.ts). Capped at
  // MAX_NOTE_IMAGES client- and server-side. Empty array = a text-only note.
  images  String[] @default([])

  // Voice recordings (Phase 3). audioUrl points at the recording in Supabase
  // Storage (the "voice-notes" bucket — see lib/voice.ts); the audio bytes are
  // NOT stored in this row (object storage keeps the DB lean). `summary` is an
  // AI-generated condensation of the transcript (content), generated on create
  // for voice notes; null when AI is unavailable or content is too short.
  audioUrl String?
  summary  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([contactId])
}

// ---------------------------------------------------------------------------
// Relationship mapping — "who knows whom" (Phase 3).
// A directed edge between two contacts. "knows" reads as symmetric; directional
// types (e.g. "introduced_by", "reports_to") read from -> to. The pair is
// de-duplicated per (fromId, toId, type). Edges power the contact-page
// Connections section and the /network graph.
// ---------------------------------------------------------------------------
model Relationship {
  id          String  @id @default(cuid())
  userId      String? // creator (kept for audit); scoping is by workspaceId
  workspaceId String? // per-account personal-workspace scope (see lib/auth.ts)

  fromId String
  toId   String
  from   Contact @relation("RelFrom", fields: [fromId], references: [id], onDelete: Cascade)
  to     Contact @relation("RelTo", fields: [toId], references: [id], onDelete: Cascade)

  // "knows" | "introduced_by" | "colleague" | "manager" | "report" | "family" |
  // "friend" | "mentor" | "client" | "investor" | "partner" | "other"
  type     String  @default("knows")
  strength Int     @default(3) // 1 (weak) .. 5 (strong)
  note     String? // optional context ("met at DevCon 2025")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([fromId, toId, type])
  @@index([userId])
  @@index([workspaceId])
  @@index([fromId])
  @@index([toId])
}

model Suggestion {
  id          String  @id @default(cuid())
  userId      String? // creator (kept for audit); scoping is by workspaceId
  workspaceId String? // per-account personal-workspace scope (see lib/auth.ts)

  contactAId String
  contactBId String
  contactA   Contact  @relation("SuggestionA", fields: [contactAId], references: [id], onDelete: Cascade)
  contactB   Contact  @relation("SuggestionB", fields: [contactBId], references: [id], onDelete: Cascade)

  rationale  String
  score      Float
  status     String   @default("pending")

  generatedAt DateTime @default(now())
  respondedAt DateTime?

  @@unique([contactAId, contactBId])
  @@index([userId, status])
  @@index([workspaceId])
}

// ---------------------------------------------------------------------------
// Workspaces epic — sub-project 1 (data model only).
// Landed additively: these tables exist and are ready, but no route enforces
// workspace scoping yet (ownership remains userId-based via lib/auth.ts).
// lib/workspace.ts holds the resolve-or-create helper for the next sub-project.
// ---------------------------------------------------------------------------

model User {
  id        String   @id // = Supabase auth.users UUID
  email     String   @unique
  name      String?

  // Self-profile — how the account holder presents themselves in their own
  // network ("who I am"), distinct from the Contacts they track ("who I know").
  // All optional; surfaced on the /profile page and powers a richer header/AI
  // context. `avatar` is a downscaled JPEG data URL (see lib/image.ts), kept on
  // the row like Contact photos rather than in object storage.
  title    String? // role / what they do
  company  String?
  location String?
  bio      String? // freeform "about me" description
  website  String? // personal site / primary link
  phone    String?
  avatar   String? // profile picture as a data URL

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships WorkspaceMember[]
}

model Workspace {
  id        String        @id @default(cuid())
  name      String
  type      WorkspaceType @default(personal)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  members  WorkspaceMember[]
  contacts Contact[]
}

enum WorkspaceType {
  personal
  team
}

model WorkspaceMember {
  id          String     @id @default(cuid())
  userId      String
  workspaceId String
  role        MemberRole @default(member)
  createdAt   DateTime   @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([userId])
}

enum MemberRole {
  owner
  admin
  member
}

// ---------------------------------------------------------------------------
// Connected accounts — Phase 3 CRM/contact integrations (D7).
// One row per (workspace, provider): the OAuth grant for an external contact
// source (HubSpot, Google Contacts, Salesforce, …). Tokens are stored
// ENCRYPTED at rest (AES-256-GCM, see lib/crypto.ts) — never plaintext. Scoped
// to a workspace like the rest of the data; nullable workspaceId keeps open
// mode working. The sync runner (lib/connectors/sync.ts) reads a connection,
// pulls contacts from the provider, and upserts them into Contact keyed on
// (workspaceId, source, externalId).
// ---------------------------------------------------------------------------
model Connection {
  id          String  @id @default(cuid())
  userId      String? // who connected it (audit); scoping is by workspaceId
  workspaceId String?

  provider     String // "hubspot" | "google" | "salesforce"
  accessToken  String // ENCRYPTED (see lib/crypto.ts)
  refreshToken String? // ENCRYPTED
  expiresAt    DateTime? // access-token expiry; refreshed lazily before a sync
  scope        String? // space-delimited granted scopes

  externalAccountId String? // provider account/portal id (for display + sanity)
  accountLabel      String? // human label: portal name / signed-in email

  status       String    @default("connected") // "connected" | "error"
  lastError    String? // last sync/refresh error message (when status = "error")
  lastSyncedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workspaceId, provider])
  @@index([workspaceId])
  @@index([userId])
}
