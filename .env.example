# Supabase Postgres — transaction-mode pooler (used by Prisma at runtime)
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Supabase Postgres — session-mode pooler (used by Prisma for migrations)
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# OpenAI — AI-assisted profile generation (optional; app works without it)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# Supabase Auth — public vars (safe to expose to browser)
# Found in: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# Voice recordings (Phase 3) need a one-time Storage bucket. Once the DATABASE_URL
# / DIRECT_URL above are set, run:  npm run setup:storage
# (creates the public "voice-notes" bucket + upload policies — see prisma/storage-setup.sql)

# ── External integrations / connectors (Phase 3, D7) ─────────────────────────
# All optional: with no CONNECTION_ENC_KEY the Connections feature is disabled.

# Encrypts stored OAuth tokens at rest (AES-256-GCM). 32 bytes as 64 hex chars:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CONNECTION_ENC_KEY=""

# Absolute app origin used to build OAuth redirect URIs. Set on Vercel so it
# matches the redirect URI registered in each provider app exactly.
APP_ORIGIN="http://localhost:3000"

# Shared secret for the daily auto-sync cron (/api/cron/sync). Set the SAME value
# in Vercel; the scheduled run sends it as `Authorization: Bearer <secret>`.
CRON_SECRET=""

# Google (Contacts + Calendar). Google Cloud Console → OAuth client (Web app).
# Enable the People API + Calendar API. Redirect URI:
#   <APP_ORIGIN>/api/connections/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft / Outlook (Contacts + Calendar). Azure Portal → App registrations.
# Delegated Graph scopes: Contacts.Read, Calendars.Read, User.Read, offline_access.
# Redirect URI: <APP_ORIGIN>/api/connections/outlook/callback
# MICROSOFT_TENANT defaults to "common" (work + personal accounts).
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT="common"

# Salesforce (Contacts). Connected App with scopes: api, refresh_token.
# Redirect URI: <APP_ORIGIN>/api/connections/salesforce/callback
SALESFORCE_CLIENT_ID=""
SALESFORCE_CLIENT_SECRET=""
SALESFORCE_LOGIN_URL="https://login.salesforce.com"

# HubSpot connects via a pasted Private-app token in the UI — no env vars needed.
